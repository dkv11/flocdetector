# Copy this to `.env.s3` and fill in real values. NEVER commit the real file.
# Generate tokens with:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# --- AWS credentials for S3 image storage ---
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET=your-bucket-name

# --- Shared secret: devices must present this to upload images ---
UPLOAD_TOKEN=generate_a_long_random_string

# --- Flask session-signing key (keeps login sessions un-forgeable) ---
FLASK_SECRET_KEY=generate_another_long_random_string
